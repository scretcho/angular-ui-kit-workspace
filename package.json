{
  "name": "ui-kit-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "ng build demo",
    "build:lib": "ng build ui-kit",
    "build:lib:watch": "ng build ui-kit --watch --configuration development",
    "build:all": "ng build ui-kit && ng build demo",
